# ═══════════════════════════════════════════════════════════════
# Ross House Rentals - Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in your values

# MongoDB Atlas
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/taxportal?retryWrites=true&w=majority
DB_NAME=taxportal

# JWT Secret
JWT_SECRET_KEY=your-secret-key-here
JWT_SECRET=your-secret-key-here

# Stripe (Payments)
STRIPE_API_KEY=sk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Twilio (SMS / OTP)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+18065914974

# SendGrid (Email)
SENDGRID_API_KEY=SG.your_sendgrid_key
SENDGRID_FROM_EMAIL=info@rosshouserentals.com

# Port (Railway sets this automatically)
# PORT=8001
